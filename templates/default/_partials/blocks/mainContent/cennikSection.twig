{% set page = block.cennikSection.one %}
<div class="blocks md:flex flex-wrap items-stretch gap-8 mb-6">
  {% for cennik in page.cennik %}
    <div class="block flex-grow-0 flex-shrink-0 flex-[30%] text-center bg-[#eeeeee]">
      <h2 class="!text-white bg-brand-yellow rounded-t-md px-4 py-3 !mt-0 !mb-0">{{ cennik.cena }}</h2>
      <h3 class="!text-white bg-[#777777] px-4 py-3 !mt-0 !mb-0 !font-normal !text-base">{{ cennik.hlavnyPopis }}</h3>
      <p class="popis bg-[#eeeeee] px-4 py-4 !text-base">{{ cennik.vedlajsiPopis|nl2br }}</p>
      {% if cennik.priplatok|length %}
        <p class="note">{{ cennik.priplatok|nl2br }}</p>
      {% endif %}
    </div>
  {% endfor %}
</div>