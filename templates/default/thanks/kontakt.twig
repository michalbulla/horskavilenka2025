                <h1 class="main-heading">Ďakujeme za správu</h1>
                <p class="message notice text-xl mb-8">Ďakujeme za Vašu správu. Ozveme sa Vám hneď, ako to bude možné.</p>
              </div>
            {% endif %}
          {% endcache %}
        {% endblock %}
      {% endembed %}
    {% endblock %}
  {% endembed %}
{% endblock %}