{% extends "_layouts/base" %}
{% set uri = entry.uri|default('blog') %}
{% set pageHeading = entry.pageHeading|default(entry.title) %}

{% set showSidebar = false %}

{% block pageLayout %}
  {% embed '_layouts/page/default' %}
    {% block contentLayout %}
      {% embed '_layouts/content/default' %}

        {% block mainContent %}
          {% cache %}
            <h1 class="main-heading">{{ pageHeading }}</h1>

            <div class="default-content">
              {% include '_partials/contentBuilder' with {contentField: entry.mainContent, blocksDir: 'mainContent'} %}
            </div>
            
            {% set catering = craft.entries.section('catering').all %}
            <div class="lg:container px-4">
              <div class="grid-block mb-12">
                {% for button in catering %}
                  <div class="grid-cell">
                    <div class="grid-image">
                      <img src="{{ button.fotka.one.url('medium') }}" alt="">
                    </div>
                    <div class="popis">
                      <h3 class="!mt-2 !mb-2 text-xl font-secondary">{{ button.title }}</h3>
                      <p class="!text-sm">{{ button.kratkyPopis }}</p>
                    </div>
                  </div>
                {% endfor %}
              </div>
            </div>
          {% endcache %}
        {% endblock %}
      {% endembed %}
    {% endblock %}
  {% endembed %}
{% endblock %}
