{% extends "_layouts/base" %}
{% set uri = entry.uri|default('blog') %}
{% set pageHeading = entry.pageHeading|default(entry.title) %}

{% set showSidebar = false %}

{% block pageLayout %}
  {% embed '_layouts/page/homePage' %}
    {% block contentLayout %}
      {% embed '_layouts/content/default' %}

        {% block mainContent %}
          {% cache %}
              <div class="lg:container px-4">
              {% if entry.buttons|length %}
                <div class="buttons md:grid md:grid-cols-3 md:gap-4 mb-16">
                  {% for button in entry.buttons.all %}
                    <a class="button md:col-span-1 mb-8 block mx-auto md:mx-0 bg-black/80 lg:bg-transparent md:mb-0 relative group" href="{{ button.buttonLink }}">
                      <img class="" src="{{ button.obrazok.one.url('medium') }}" alt="">
                      <div class="popis text-center lg:absolute bottom-0 left-0 w-full lg:bg-black/70 px-2 py-3 lg:group-hover:-translate-y-full duration-300">
                        <h2 class="text-xl font-semibold mb-1 text-white">{{ button.nadpis }}</h2>
                        <p class="text-white !mb-0 tracking-tight md:!text-[15px]">{{ button.popis }}</p>
                      </div>
                    </a>
                  {% endfor %}
                </div>
                <div class="video">
                  <iframe width="560" height="315" src="https://www.youtube.com/embed/uEXmyEQnbVc" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                </div>
                <br/><br/>
                
              {% endif %}
              <h1 class="main-heading">{{ pageHeading }}</h1>
              <div class="default-content">
                {% include '_partials/contentBuilder' with {contentField: entry.mainContent, blocksDir: 'mainContent'} %}
              </div>
            </div>
          {% endcache %}
        {% endblock %}
      {% endembed %}
    {% endblock %}
  {% endembed %}
{% endblock %}

 {# Fancybox js and css code #}
  {% css "https://cdn.jsdelivr.net/npm/@fancyapps/ui@4.0/dist/fancybox.css" %}
  {% js "https://cdn.jsdelivr.net/npm/@fancyapps/ui@4.0/dist/fancybox.umd.js" %}
